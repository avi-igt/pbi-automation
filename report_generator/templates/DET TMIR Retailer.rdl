  <DataSources>
    <DataSource Name="LPC_E2_SFODBC">
      <rd:SecurityType>Integrated</rd:SecurityType>
      <ConnectionProperties>
        <DataProvider>ODBC</DataProvider>
        <ConnectString>Dsn=SF-NonProd</ConnectString>
        <IntegratedSecurity>true</IntegratedSecurity>
      </ConnectionProperties>
      <rd:DataSourceID>dc57e7f7-a1b8-409e-8c87-13b1a93d9044</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>LPC_E2_SFODBC</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="?">
            <Value>=Format(Parameters!startDate.Value,"yyyy-MM-dd")</Value>
          </QueryParameter>
          <QueryParameter Name="?">
            <Value>=Format(Parameters!endDate.Value,"yyyy-MM-dd")</Value>
          </QueryParameter>
          <QueryParameter Name="?">
            <Value>=JOIN(Parameters!productNumber.Value,",")</Value>
          </QueryParameter>
          <QueryParameter Name="?">
            <Value>=JOIN(Parameters!tranType.Value,",")</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT TXN_DATE as DATE, TXN_TIME AS TIME, MAIN_TXN.DATE_KEY AS CDC, MAIN_TXN.LOCATION_NUMBER AS RETAILER_ID, MAIN_TXN.TERMINAL_NUMBER AS TERMINAL_ID, 
TXN_TYPE_DESC AS TRANSACTION_TYPE,COALESCE(NULLIF(UPPER(TRIM(PLAY_IT_AGAIN_IND)), 'N'), 'NA') AS PLAYITAGAIN_IND, NUMBER_OF_BOARDS AS DUR,
TO_CHAR((MAIN_TXN.TXN_AMOUNT), '$999,999,999,990.00')  AS Transaction_Amount,
EXTERNAL_SERIAL_NUMBER_FORMATTED AS TRANSACTION_EXT_SERIAL, 
TXN_REJECTED_FLAG AS REJECT_FLAG, 
ERROR_DESC AS ERROR_CODE_DESC, 
INSTANT_VALIDATION.PRODUCT_NUMBER AS INSTANT_GAME, NULLIF(INSTANT_PACK_NUMBER,-1) AS PACK, NULLIF(INSTANT_TICKET_NUMBER,-1) AS TICKET, 
NULLIF(BEGIN_DRAW_NUMBER,-1) AS FIRST_DRAW_NUMBER,
PROMO_NUMBER AS PROMO_NUMBER, 
FINANCIAL_FLAG AS UPDATE_MONEY
FROM TXNDTL.MAIN_TXN LEFT OUTER JOIN TXNDTL.PROMOTION ON
(MAIN_TXN.DATE_KEY = PROMOTION.DATE_KEY AND MAIN_TXN.SERIAL_NUMBER = PROMOTION.SERIAL_NUMBER AND MAIN_TXN.PRODUCT_NUMBER = PROMOTION.PRODUCT_NUMBER)
LEFT OUTER JOIN TXNDTL.INSTANT_VALIDATION ON
(MAIN_TXN.DATE_KEY = INSTANT_VALIDATION.DATE_KEY AND MAIN_TXN.SERIAL_NUMBER = INSTANT_VALIDATION.SERIAL_NUMBER AND MAIN_TXN.PRODUCT_NUMBER = INSTANT_VALIDATION.PRODUCT_NUMBER)
LEFT OUTER JOIN TXNDTL.DRAW_WAGER ON
(MAIN_TXN.DATE_KEY = DRAW_WAGER.DATE_KEY AND MAIN_TXN.SERIAL_NUMBER = DRAW_WAGER.SERIAL_NUMBER AND MAIN_TXN.PRODUCT_NUMBER = DRAW_WAGER.PRODUCT_NUMBER)
WHERE
 (TXNDTL.MAIN_TXN.date_key) &gt;= (select date_key from dimcore.dates where calendar_day_date=? :: DATE ) 
and (TXNDTL.MAIN_TXN.date_key) &lt;= (select date_key from dimcore.dates where calendar_day_date=?:: date ) 
and (TXNDTL.MAIN_TXN.GAME_PRODUCT_NUMBER in (SELECT t.VALUE::number  FROM TABLE(SPLIT_TO_TABLE(?, ',')) t  ) )
AND ( MAIN_TXN.TXN_TYPE_Code in (SELECT T.VALUE FROM TABLE(SPLIT_TO_TABLE(?,',' ))T ))

ORDER BY TXN_DATE, TXN_TIME</CommandText>
      </Query>
      <Fields>
        <Field Name="DATE">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>DATE</DataField>
        </Field>
        <Field Name="TIME">
          <rd:TypeName>System.TimeSpan</rd:TypeName>
          <DataField>TIME</DataField>
        </Field>
        <Field Name="CDC">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>CDC</DataField>
        </Field>
        <Field Name="RETAILER_ID">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>RETAILER_ID</DataField>
        </Field>
        <Field Name="TERMINAL_ID">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>TERMINAL_ID</DataField>
        </Field>
        <Field Name="PLAYITAGAIN_IND">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>PLAYITAGAIN_IND</DataField>
        </Field>
        <Field Name="DUR">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>DUR</DataField>
        </Field>
        <Field Name="TRANSACTION_AMOUNT">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>TRANSACTION_AMOUNT</DataField>
        </Field>
        <Field Name="TRANSACTION_EXT_SERIAL">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>TRANSACTION_EXT_SERIAL</DataField>
        </Field>
        <Field Name="REJECT_FLAG">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>REJECT_FLAG</DataField>
        </Field>
        <Field Name="ERROR_CODE_DESC">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ERROR_CODE_DESC</DataField>
        </Field>
        <Field Name="INSTANT_GAME">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>INSTANT_GAME</DataField>
        </Field>
        <Field Name="PACK">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>PACK</DataField>
        </Field>
        <Field Name="TICKET">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>TICKET</DataField>
        </Field>
        <Field Name="FIRST_DRAW_NUMBER">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>FIRST_DRAW_NUMBER</DataField>
        </Field>
        <Field Name="PROMO_NUMBER">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>PROMO_NUMBER</DataField>
        </Field>
        <Field Name="UPDATE_MONEY">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>UPDATE_MONEY</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Products">
      <Query>
        <DataSourceName>LPC_E2_SFODBC</DataSourceName>
        <CommandText>SELECT PRODUCT_DESC, PRODUCT_NUMBER FROM DIMCORE.PRODUCTS WHERE PRODUCT_TYPE_CODE=0</CommandText>
      </Query>
      <Fields>
        <Field Name="PRODUCT_DESC">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>PRODUCT_DESC</DataField>
        </Field>
        <Field Name="PRODUCT_NUMBER">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>PRODUCT_NUMBER</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="TranTypes">
      <Query>
        <DataSourceName>LPC_E2_SFODBC</DataSourceName>
        <CommandText>SELECT CODE,DESC1 FROM DIMCORE.CODES WHERE CATEGORY LIKE '%TransactionTypes%' order by code::NUMBER</CommandText>
      </Query>
      <Fields>
        <Field Name="CODE">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CODE</DataField>
        </Field>
        <Field Name="DESC1">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>DESC1</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
